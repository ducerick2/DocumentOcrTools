[{"id":"17711751104420xc25x","imageId":"1771175110442-606204490-10017.png","datasetId":"1771174392011","label":"title","type":"bbox","x":119.92500000000001,"y":61.5,"width":493.0249999999999,"height":33.825,"points":null,"content":"Management’s Responsibility","reading_order":0,"sync":{"sourceBaseDir":"/data/ducbm3/DocumentOCR/dataset_public/DocLayNet_extracted/train/financial_reports/autopass","originalImageId":"10017","originalWidth":1025,"originalHeight":1025},"createdAt":"2026-02-15T17:05:10.442Z"},{"id":"177117511044210tjc2","imageId":"1771175110442-606204490-10017.png","datasetId":"1771174392011","label":"text","type":"bbox","x":319.8,"y":138.375,"width":499.175,"height":54.32499999999999,"points":null,"content":"The accompanying consolidated financial statements are the responsibility of management and have been prepared in accordance with generally accepted accounting principles.","reading_order":1,"sync":{"sourceBaseDir":"/data/ducbm3/DocumentOCR/dataset_public/DocLayNet_extracted/train/financial_reports/autopass","originalImageId":"10017","originalWidth":1025,"originalHeight":1025},"createdAt":"2026-02-15T17:05:10.442Z"},{"id":"17711751104422z79t0","imageId":"1771175110442-606204490-10017.png","datasetId":"1771174392011","label":"text","type":"bbox","x":319.8,"y":199.875,"width":580.1500000000001,"height":97.375,"points":null,"content":"The preparation of financial statements necessarily involves the use of estimates based on management's judgment, particularly when transactions affecting the current accounting period cannot be finalized with certainty until future periods. The consolidated financial statements have been properly prepared within reasonable limits of materiality and in light of information available up to March 12, 2004.","reading_order":2,"sync":{"sourceBaseDir":"/data/ducbm3/DocumentOCR/dataset_public/DocLayNet_extracted/train/financial_reports/autopass","originalImageId":"10017","originalWidth":1025,"originalHeight":1025},"createdAt":"2026-02-15T17:05:10.442Z"},{"id":"1771175110442307zz3","imageId":"1771175110442-606204490-10017.png","datasetId":"1771174392011","label":"text","type":"bbox","x":319.8,"y":303.4,"width":538.125,"height":56.375,"points":null,"content":"Management is also responsible for the maintenance of financial and operating systems, which include effective controls to provide reasonable assurance that the Company's assets are safeguarded and that reliable financial information is produced.","reading_order":3,"sync":{"sourceBaseDir":"/data/ducbm3/DocumentOCR/dataset_public/DocLayNet_extracted/train/financial_reports/autopass","originalImageId":"10017","originalWidth":1025,"originalHeight":1025},"createdAt":"2026-02-15T17:05:10.442Z"},{"id":"17711751104424gvjcc","imageId":"1771175110442-606204490-10017.png","datasetId":"1771174392011","label":"text","type":"bbox","x":319.8,"y":365.925,"width":574,"height":115.82499999999999,"points":null,"content":"The Board of Directors is responsible for ensuring that management fulfills its responsibilities through its Audit Committee whose members are not involved in day-to-day operations of the Company. Each quarter the Audit Committee meets with management and, as necessary, with the independent auditors, Deloitte & Touche LLP, to satisfy itself that management's responsibilities are properly discharged and to review and report to the Board on the consolidated financial statements.","reading_order":4,"sync":{"sourceBaseDir":"/data/ducbm3/DocumentOCR/dataset_public/DocLayNet_extracted/train/financial_reports/autopass","originalImageId":"10017","originalWidth":1025,"originalHeight":1025},"createdAt":"2026-02-15T17:05:10.442Z"},{"id":"1771175110443597udw","imageId":"1771175110442-606204490-10017.png","datasetId":"1771174392011","label":"text","type":"bbox","x":319.8,"y":488.92499999999995,"width":564.7750000000001,"height":55.35000000000002,"points":null,"content":"In accordance with generally accepted auditing standards, the independent auditors conduct an examination each year in order to express a professional opinion on the consolidated financial statements.","reading_order":5,"sync":{"sourceBaseDir":"/data/ducbm3/DocumentOCR/dataset_public/DocLayNet_extracted/train/financial_reports/autopass","originalImageId":"10017","originalWidth":1025,"originalHeight":1025},"createdAt":"2026-02-15T17:05:10.443Z"},{"id":"17711751104436y0cy8","imageId":"1771175110442-606204490-10017.png","datasetId":"1771174392011","label":"text","type":"bbox","x":319.8,"y":613.975,"width":238.825,"height":34.85000000000002,"points":null,"content":"Dori J. Segal\nPresident and Chief Executive Officer","reading_order":6,"sync":{"sourceBaseDir":"/data/ducbm3/DocumentOCR/dataset_public/DocLayNet_extracted/train/financial_reports/autopass","originalImageId":"10017","originalWidth":1025,"originalHeight":1025},"createdAt":"2026-02-15T17:05:10.443Z"},{"id":"17711751104437dz15g","imageId":"1771175110442-606204490-10017.png","datasetId":"1771174392011","label":"text","type":"bbox","x":661.125,"y":613.975,"width":144.52499999999998,"height":34.85000000000002,"points":null,"content":"Karen H. Weaver, CPA\nChief Financial Officer","reading_order":7,"sync":{"sourceBaseDir":"/data/ducbm3/DocumentOCR/dataset_public/DocLayNet_extracted/train/financial_reports/autopass","originalImageId":"10017","originalWidth":1025,"originalHeight":1025},"createdAt":"2026-02-15T17:05:10.443Z"},{"id":"17711751104438s4cpg","imageId":"1771175110442-606204490-10017.png","datasetId":"1771174392011","label":"page_number","type":"bbox","x":126.075,"y":968.625,"width":17.424999999999997,"height":13.324999999999932,"points":null,"content":"46","reading_order":8,"sync":{"sourceBaseDir":"/data/ducbm3/DocumentOCR/dataset_public/DocLayNet_extracted/train/financial_reports/autopass","originalImageId":"10017","originalWidth":1025,"originalHeight":1025},"createdAt":"2026-02-15T17:05:10.443Z"},{"id":"177117511044395mv3n","imageId":"1771175110442-606204490-10017.png","datasetId":"1771174392011","label":"text","type":"bbox","x":161.95,"y":970.675,"width":216.27500000000003,"height":11.274999999999977,"points":null,"content":"First Capital Realty Annual Report 2003","reading_order":9,"sync":{"sourceBaseDir":"/data/ducbm3/DocumentOCR/dataset_public/DocLayNet_extracted/train/financial_reports/autopass","originalImageId":"10017","originalWidth":1025,"originalHeight":1025},"createdAt":"2026-02-15T17:05:10.443Z"}]